<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система контролю часу та планування" Height="600" Width="800" Background="#FFF3F4F6">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,10,0" VerticalAlignment="Center" Padding="8" BorderBrush="#E5E7EB" BorderThickness="1"
                         ToolTip="Введіть назву задачі..."/>
                         
                <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                          Margin="0,0,10,0" Width="110" VerticalContentAlignment="Center" BorderBrush="#E5E7EB"/>

                <DatePicker Grid.Column="2" SelectedDate="{Binding NewTaskDeadline}" 
                            Margin="0,0,10,0" Width="110" VerticalContentAlignment="Center" BorderBrush="#E5E7EB"
                            ToolTip="Оберіть дедлайн"/>
                          
                <Button Grid.Column="3" Content="Додати" Command="{Binding AddTaskCommand}" 
                        Padding="15,8" Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="Всі" Command="{Binding FilterCommand}" CommandParameter="All" Margin="0,0,5,0" Padding="10,5" Background="White" BorderBrush="#E5E7EB"/>
                <Button Content="Активні" Command="{Binding FilterCommand}" CommandParameter="Active" Margin="0,0,5,0" Padding="10,5" Background="White" BorderBrush="#E5E7EB"/>
                <Button Content="Історія" Command="{Binding FilterCommand}" CommandParameter="Completed" Padding="10,5" Background="White" BorderBrush="#E5E7EB"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                
                <Button Command="{Binding SortCommand}" CommandParameter="Urgency" 
                        Margin="0,0,5,0" Padding="12,6" Background="#1F2937" BorderThickness="0" Cursor="Hand"
                        ToolTip="Спочатку прострочені та найближчі">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="Термінові" Foreground="White" FontWeight="SemiBold"/>
                </Button>
                
                <Button Command="{Binding SortCommand}" CommandParameter="Title" 
                        Padding="12,6" Background="#1F2937" BorderThickness="0" Cursor="Hand"
                        ToolTip="Сортування за алфавітом">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="За назвою" Foreground="White" FontWeight="SemiBold"/>
                </Button>

            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding TasksView}" SelectedItem="{Binding SelectedTask}" 
                     HorizontalContentAlignment="Stretch" BorderThickness="0" Background="Transparent" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#4B5563" FontSize="14" Margin="0,10,0,5"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Margin="0,0,0,5" Padding="10" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, UpdateSourceTrigger=PropertyChanged}" 
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                                          
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <TextBlock Text="{Binding Deadline, StringFormat='Дедлайн: {0:dd.MM.yyyy}'}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#6B7280"/> 
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Text" Value="{Binding Deadline, StringFormat='ПРОСТРОЧЕНО: {0:dd.MM.yyyy}'}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                
                                <Button Grid.Column="3" Content="✕" Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        Background="Transparent" BorderThickness="0" Foreground="#EF4444" FontWeight="Bold" Cursor="Hand" Margin="5,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="1" Margin="15,0,0,0" Padding="20" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Top">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Обрана задача:" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedTask.Title}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" 
                               Margin="0,5,0,15" TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <TextBlock Text="{Binding SelectedTask.FormattedTime, TargetNullValue='00:00:00', FallbackValue='00:00:00'}" 
                               FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#1F2937"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Старт" Command="{Binding StartTimerCommand}" 
                                Margin="0,0,5,0" Padding="10" Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button Grid.Column="1" Content="Стоп" Command="{Binding StopTimerCommand}" 
                                Margin="5,0,0,0" Padding="10" Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#1F2937" Padding="10,5" CornerRadius="5" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Foreground="White" Margin="0,0,15,0">
                    <Run Text="Всього задач: " FontWeight="SemiBold"/>
                    <Run Text="{Binding TotalTasksCount}"/>
                </TextBlock>

                <TextBlock Grid.Column="1" Foreground="White" Margin="0,0,15,0">
                    <Run Text="Виконано: " FontWeight="SemiBold"/>
                    <Run Text="{Binding CompletedTasksCount}"/>
                </TextBlock>

                <TextBlock Grid.Column="3" Foreground="#FCD34D" FontWeight="Bold">
                    <Run Text="Загальний час: "/>
                    <Run Text="{Binding TotalTimeSpent}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>